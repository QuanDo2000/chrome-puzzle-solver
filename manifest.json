{
  "manifest_version": 3,
  "name": "Puzzle Solver",
  "version": "1.0",
  "description": "Solves puzzles",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.puzzles-mobile.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Puzzle Solver",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.puzzles-mobile.com/*"],
      "js": ["solver.js", "handler.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["solver.js", "solver.worker.js"],
      "matches": ["https://www.puzzles-mobile.com/*"]
    }
  ]
}
