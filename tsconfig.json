{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "WebWorker"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["solver.js", "solver.worker.js", "content.js", "handler.js", "background.js", "main-world.js", "globals.d.ts"],
  "exclude": ["node_modules", "tests", "docs"]
}
